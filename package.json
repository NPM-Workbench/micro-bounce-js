{
  "name": "micro-bounce-js",
  "description": "A tiny, type-safe debounce utility for modern JavaScript and TypeScript. Lightweight and dependency-free.",
  "keywords": [
    "debounce",
    "debouncer",
    "debouncing",
    "micro",
    "tiny",
    "utility",
    "typescript",
    "ts",
    "node",
    "browser",
    "lightweight",
    "functional",
    "timer",
    "performance"
  ],
  "license": "MIT",
  "version": "1.1.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --verbose"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/NPM-Workbench/micro-bounce-js.git"
  },
  "author": {
